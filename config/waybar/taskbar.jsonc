{
    "layer": "top",
    "position": "left",
    "width": 48,
    "height": 511,
    "modules-center": ["wlr/taskbar"],

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 36,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    }
}
